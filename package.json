      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "devDependencies": {
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "turbo": "^2.8.10",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.29.3"
}
