{
  "name": "f1-data-hub",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "db:schema:pull": "turbo run db:schema:pull",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "predev": "docker compose up -d"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "devDependencies": {
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "turbo": "^2.5.6",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@10.14.0"
}
