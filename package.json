{
  "name": "f1-data-hub",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "db:schema:pull": "turbo run db:schema:pull",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "predev": "docker compose up -d"
  },
  "engines": {
    "node": ">=22.22.0"
  },
  "config": {
