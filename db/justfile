set dotenv-load

build:
    uv run python -m scripts.build

check: lint format-check typecheck

dbt-deps:
    uv run dbt deps --project-dir ./dbt --profiles-dir ./dbt

dbt-debug:
    uv run dbt debug --project-dir ./dbt --profiles-dir ./dbt

dbt-parse:
    uv run dbt parse --project-dir ./dbt --profiles-dir ./dbt

format:
    uv run ruff format .

format-check:
    uv run ruff format --check .

lint:
    uv run ruff check .

load:
    uv run python -m scripts.load

migrate:
    goose -table app_goose_db_version -dir ./migrations postgres "$DATABASE_URL" up

migrate-down:
    goose -table app_goose_db_version -dir ./migrations postgres "$DATABASE_URL" down

migrate-status:
    goose -table app_goose_db_version -dir ./migrations postgres "$DATABASE_URL" status

refresh: load build

typecheck:
    uv run pyrefly check .
