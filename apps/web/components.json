{
    "$schema": "https://ui.shadcn.com/schema.json",
    "style": "new-york",
    "rsc": false,
    "tsx": true,
    "tailwind": {
        "config": "",
        "css": "src/styles.css",
        "baseColor": "neutral",
        "cssVariables": true,
        "prefix": ""
    },
    "aliases": {
        "components": "@/components",
        "utils": "@/lib/utils",
        "ui": "@/components/ui",
        "lib": "@/lib",
        "hooks": "@/hooks"
    },
    "iconLibrary": "phosphor",
    "registries": {
        "@ss-components": {
            "url": "https://shadcnstudio.com/r/components/{style}/{name}.json",
            "params": {
                "email": "${SHADCN_EMAIL}",
                "license_key": "${SHADCN_LICENSE_KEY}"
            }
        },
        "@ss-themes": {
            "url": "https://shadcnstudio.com/r/themes/{name}.json",
            "params": {
                "email": "${SHADCN_EMAIL}",
                "license_key": "${SHADCN_LICENSE_KEY}"
            }
        },
        "@ss-blocks": {
            "url": "https://shadcnstudio.com/r/blocks/{style}/{name}.json",
            "params": {
                "email": "${SHADCN_EMAIL}",
                "license_key": "${SHADCN_LICENSE_KEY}"
            }
        }
    }
}
