{
    "$schema": "https://turborepo.com/schema.json",
    "ui": "stream",
    "globalEnv": [
        "API_HOST",
        "API_PORT",
        "DATABASE_URL"
    ],
    "tasks": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "inputs": [
                "$TURBO_DEFAULT$",
                ".env*"
            ],
            "outputs": [
                ".next/**",
                "!.next/cache/**"
            ]
        },
        "lint": {
            "dependsOn": [
                "^lint"
            ]
        },
        "check-types": {
            "dependsOn": [
                "^check-types"
            ]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "db:schema:pull": {
            "cache": false
        },
    }
}
